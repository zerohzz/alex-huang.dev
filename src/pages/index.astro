---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">

    <!-- Hero Section -->
    <section
      class="mx-auto w-full max-w-5xl px-4 py-12 md:py-20 flex flex-col-reverse md:flex-row items-center justify-between gap-12"
    >
      <!-- Left column -->
      <div class="w-full md:w-[60%] flex flex-col items-center md:items-start text-center md:text-left">

        <div data-fade-up data-delay="0.1">
          <h1 class="text-4xl md:text-6xl font-bold mb-2 text-foreground">
            Hi, I'm <br class="hidden md:block" />Alex Huang
          </h1>
        </div>

        <div data-fade-up data-delay="0.2">
          <div class="h-10 md:h-14 mb-6 flex items-center">
            <span
              id="typed-text"
              class="text-xl md:text-3xl font-semibold text-accent"
              aria-live="polite"
            ></span>
            <span class="text-xl md:text-3xl font-semibold text-accent typing-cursor">|</span>
          </div>
        </div>

        <div data-fade-up data-delay="0.3">
          <p class="text-sm md:text-base text-text-muted mb-8 max-w-xl leading-relaxed">
            {SITE.desc}
          </p>
        </div>

        <div data-fade-up data-delay="0.4">
          <div class="mb-8">
            <Socials />
          </div>
        </div>

        <div data-fade-up data-delay="0.5">
          <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 mb-8">
            <a
              href="/resume"
              data-magnetic="0.15"
              class="inline-block px-6 py-3 bg-accent text-white font-medium rounded-lg hover:opacity-90 transition-opacity"
            >
              View Resume
            </a>
            <a
              href="/posts"
              data-magnetic="0.15"
              class="inline-block px-6 py-3 bg-card-muted text-foreground font-medium rounded-lg border border-border hover:border-accent transition-colors"
            >
              Read Blog
            </a>
          </div>
        </div>

        <div data-fade-up data-delay="0.6">
          <div class="flex items-center gap-2 text-sm text-text-muted font-medium">
            <svg class="w-4 h-4 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Melbourne, Australia</span>
          </div>
        </div>

      </div>

      <!-- Right column: decorative placeholder -->
      <div data-fade-up data-delay="0.3" class="w-full md:w-[40%] flex justify-center md:justify-end">
        <div class="relative w-64 h-64 md:w-72 md:h-72">
          <div class="absolute inset-0 -translate-x-4 translate-y-4 dot-pattern rounded-2xl z-0 opacity-30"></div>
          <div
            class="relative z-10 w-full h-full rounded-2xl overflow-hidden shadow-md border border-border bg-card flex flex-col items-center justify-center text-center p-4"
          >
            <div class="text-6xl font-bold text-text-muted opacity-20 mb-2">AH</div>
            <div class="text-xs text-text-muted opacity-40 font-medium uppercase tracking-widest">
              Profile<br />Photo
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Posts -->
    {
      featuredPosts.length > 0 && (
        <section class="mx-auto w-full max-w-5xl px-4 pb-8 border-t border-border pt-12">
          <h2 data-fade-up class="text-2xl font-semibold mb-6 text-foreground">Featured</h2>
          <ul data-fade-up data-delay="0.1" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <!-- Recent Posts -->
    {
      recentPosts.length > 0 && (
        <section class="mx-auto w-full max-w-5xl px-4 pb-12 border-t border-border pt-12">
          <h2 data-fade-up class="text-2xl font-semibold mb-6 text-foreground">Recent Posts</h2>
          <ul data-fade-up data-delay="0.1" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 list-none p-0">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center" data-fade-up>
      <a
        href="/posts/"
        class="inline-flex items-center gap-2 px-6 py-3 border border-border rounded-lg text-text-muted hover:border-accent hover:text-accent transition-colors font-medium"
      >
        All Posts
        <IconArrowRight class="inline-block" />
      </a>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    // Typing effect
    const typedText = document.getElementById("typed-text");
    if (!typedText) return;

    const ROLES = [
      "Salesforce Engineer",
      "LWC Developer",
      "AI-assisted Developer",
    ];

    let roleIndex = 0;
    let charIndex = 0;
    let deleting = false;
    let timeoutId: ReturnType<typeof setTimeout>;

    function type() {
      if (!typedText) return;
      const currentRole = ROLES[roleIndex];

      if (deleting) {
        typedText.textContent = currentRole.substring(0, charIndex - 1);
        charIndex--;
      } else {
        typedText.textContent = currentRole.substring(0, charIndex + 1);
        charIndex++;
      }

      let speed = deleting ? 60 : 120;

      if (!deleting && charIndex === currentRole.length) {
        speed = 1500;
        deleting = true;
      } else if (deleting && charIndex === 0) {
        deleting = false;
        roleIndex = (roleIndex + 1) % ROLES.length;
        speed = 500;
      }

      timeoutId = setTimeout(type, speed);
    }

    timeoutId = setTimeout(type, 400);

    document.addEventListener(
      "astro:before-swap",
      () => clearTimeout(timeoutId),
      { once: true }
    );
  });
</script>
