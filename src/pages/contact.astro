---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Contact | ${SITE.title}`} description="Get in touch with Alex Huang — Salesforce Engineer, Melbourne.">
  <Header />
  <main id="main-content" class="w-full max-w-5xl mx-auto px-4 py-12 md:py-20">

    <header class="mb-12" data-fade-up>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Get in Touch</h1>
      <p class="text-text-muted text-lg max-w-xl">
        Open to opportunities, collaborations, and interesting conversations about Salesforce, AI-assisted development, and engineering automation.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl" data-fade-up data-delay="0.1">

      <!-- Email -->
      <a
        href="mailto:alexander-huang@outlook.com"
        data-magnetic="0.1"
        class="flex items-start gap-4 p-6 rounded-xl border border-border bg-card shadow-sm hover:border-accent hover:shadow-md transition-all group"
      >
        <div class="w-10 h-10 rounded-full bg-card-muted flex items-center justify-center shrink-0 group-hover:bg-accent/10 transition-colors">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-1">Email</p>
          <p class="font-medium text-foreground group-hover:text-accent transition-colors break-all">
            alexander-huang@outlook.com
          </p>
        </div>
      </a>

      <!-- Location -->
      <div class="flex items-start gap-4 p-6 rounded-xl border border-border bg-card shadow-sm">
        <div class="w-10 h-10 rounded-full bg-card-muted flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-1">Location</p>
          <p class="font-medium text-foreground">Melbourne, Australia</p>
        </div>
      </div>

      <!-- GitHub -->
      <a
        href="https://github.com/zerohzz"
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic="0.1"
        class="flex items-start gap-4 p-6 rounded-xl border border-border bg-card shadow-sm hover:border-accent hover:shadow-md transition-all group"
      >
        <div class="w-10 h-10 rounded-full bg-card-muted flex items-center justify-center shrink-0 group-hover:bg-accent/10 transition-colors">
          <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-1">GitHub</p>
          <p class="font-medium text-foreground group-hover:text-accent transition-colors">github.com/zerohzz</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/azhua/"
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic="0.1"
        class="flex items-start gap-4 p-6 rounded-xl border border-border bg-card shadow-sm hover:border-accent hover:shadow-md transition-all group"
      >
        <div class="w-10 h-10 rounded-full bg-card-muted flex items-center justify-center shrink-0 group-hover:bg-accent/10 transition-colors">
          <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-1">LinkedIn</p>
          <p class="font-medium text-foreground group-hover:text-accent transition-colors">linkedin.com/in/azhua</p>
        </div>
      </a>

    </div>
  </main>
  <Footer />
</Layout>
