    // ─── 7: Magnifying Lens / 放大镜效果 ──────────────────────
    (() => {
      const stage  = document.querySelector('#magnify .img-stage') as HTMLElement;
      const img    = document.getElementById('magnify-src') as HTMLImageElement;
      const canvas = document.getElementById('magnify-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const RADIUS = 55, ZOOM = 2.6;

      canvas.width  = stage.offsetWidth;
      canvas.height = stage.offsetHeight;

      let mx = -999, my = -999, visible = false;

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        if (!visible) return;

        const iw = img.naturalWidth  || canvas.width;
        const ih = img.naturalHeight || canvas.height;
        const scaleX = iw / canvas.width;
        const scaleY = ih / canvas.height;

        // Circular clip
        ctx.save();
        ctx.beginPath();
        ctx.arc(mx, my, RADIUS, 0, Math.PI * 2);
        ctx.clip();

        // Draw zoomed image
        const sx = mx * scaleX - (RADIUS * scaleX) / ZOOM;
        const sy = my * scaleY - (RADIUS * scaleY) / ZOOM;
        const sw = (RADIUS * 2 * scaleX) / ZOOM;
        const sh = (RADIUS * 2 * scaleY) / ZOOM;
        ctx.drawImage(img, sx, sy, sw, sh, mx - RADIUS, my - RADIUS, RADIUS * 2, RADIUS * 2);
        ctx.restore();

        // Glass ring — outer
        ctx.beginPath();
        ctx.arc(mx, my, RADIUS, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(255,255,255,0.55)';
        ctx.lineWidth = 2.5;
        ctx.stroke();

        // Inner shadow at bottom
        const grad = ctx.createRadialGradient(mx, my - RADIUS * 0.3, RADIUS * 0.2, mx, my, RADIUS);
        grad.addColorStop(0, 'rgba(255,255,255,0.12)');
        grad.addColorStop(1, 'rgba(0,0,0,0.22)');
        ctx.beginPath();
        ctx.arc(mx, my, RADIUS - 1, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      }

      stage.addEventListener('mouseenter', () => { visible = true; });
      stage.addEventListener('mouseleave', () => { visible = false; ctx.clearRect(0, 0, canvas.width, canvas.height); });
      stage.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        mx = e.clientX - rect.left;
        my = e.clientY - rect.top;
        draw();
      });
    })();

    // ─── 8: ASCII Art / ASCII 字符画 ──────────────────────────
    (() => {
      const stage  = document.querySelector('#ascii .img-stage') as HTMLElement;
      const img    = document.getElementById('ascii-src') as HTMLImageElement;
      const canvas = document.getElementById('ascii-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;

      const COLS = 38, ROWS = 50;
      const CHARS = ' .,:;i1tfLCG08@';
      let rendered = false;

      canvas.width  = stage.offsetWidth;
      canvas.height = stage.offsetHeight;

      function render() {
        if (rendered) return;
        rendered = true;

        const off = document.createElement('canvas');
        off.width = COLS; off.height = ROWS;
        const octx = off.getContext('2d')!;
        octx.drawImage(img, 0, 0, COLS, ROWS);
        const data = octx.getImageData(0, 0, COLS, ROWS).data;

        const cw = canvas.width  / COLS;
        const ch = canvas.height / ROWS;
        const fs = Math.min(cw, ch) * 0.85;

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.font = `bold ${fs.toFixed(1)}px monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';

        for (let row = 0; row < ROWS; row++) {
          for (let col = 0; col < COLS; col++) {
            const idx = (row * COLS + col) * 4;
            const r = data[idx], g = data[idx+1], b = data[idx+2];
            const brightness = (r * 0.299 + g * 0.587 + b * 0.114) / 255;
            const charIdx = Math.floor(brightness * (CHARS.length - 1));
            const ch2 = CHARS[charIdx];
            ctx.fillStyle = `rgb(${r},${g},${b})`;
            ctx.fillText(ch2, (col + 0.5) * cw, (row + 0.5) * canvas.height / ROWS);
          }
        }
      }

      // Pre-render after image loads
      if (img.complete) render();
      else img.addEventListener('load', render);

      // The CSS opacity transition handles show/hide on hover
    })();

