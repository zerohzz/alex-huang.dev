    // ─── 12: Perlin Flow Field / 柏林流场 ─────────────────────
    (() => {
      const stage  = document.querySelector('#flow-field .img-stage') as HTMLElement;
      const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;

      // Compact Perlin noise
      const perm = new Uint8Array(512);
      { const p = new Uint8Array(256);
        for (let i=0;i<256;i++) p[i]=i;
        for (let i=255;i>0;i--) { const j=Math.floor(Math.random()*(i+1)); [p[i],p[j]]=[p[j],p[i]]; }
        for (let i=0;i<512;i++) perm[i]=p[i&255]; }
      const fd = (t:number)=>t*t*t*(t*(t*6-15)+10);
      const lp = (a:number,b:number,t:number)=>a+t*(b-a);
      const gr2 = (h:number,x:number,y:number)=>{ const g=h&3; return (g<2?g===0?x:-x:0)+(g<2?0:g===2?y:-y); };
      function noise(x:number,y:number){
        const X=Math.floor(x)&255,Y=Math.floor(y)&255;
        x-=Math.floor(x); y-=Math.floor(y);
        const u=fd(x),v=fd(y),a=perm[X]+Y,b=perm[X+1]+Y;
        return lp(lp(gr2(perm[a],x,y),gr2(perm[b],x-1,y),u),lp(gr2(perm[a+1],x,y-1),gr2(perm[b+1],x-1,y-1),u),v);
      }

      interface FP { x:number; y:number; hue:number; }
      const fps: FP[] = [];
      for (let i=0;i<200;i++) fps.push({ x:Math.random()*CW, y:Math.random()*CH, hue:180+Math.random()*80 });
      let t = 0;

      function frame() {
        t += 0.0025;
        for (const p of fps) {
          const angle = noise(p.x*0.006, p.y*0.006+t) * Math.PI * 4;
          const nx = p.x + Math.cos(angle)*1.4;
          const ny = p.y + Math.sin(angle)*1.4;
          ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(nx, ny);
          ctx.strokeStyle = `hsla(${p.hue},85%,70%,0.22)`;
          ctx.lineWidth = 0.9; ctx.stroke();
          p.x = nx < 0 ? CW : nx > CW ? 0 : nx;
          p.y = ny < 0 ? CH : ny > CH ? 0 : ny;
        }
        requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
    })();

    // ─── 13: Magnetic Card / 磁力悬浮 ─────────────────────────
    (() => {
