    // ─── 4: Liquid Distortion / 液态扭曲 ──────────────────────
    (() => {
      const stage   = document.querySelector('#liquid .img-stage') as HTMLElement;
      const turb    = document.getElementById('turb') as unknown as SVGFETurbulenceElement;
      const dispmap = document.getElementById('dispmap') as unknown as SVGFEDisplacementMapElement;
      let seed = 2, tFreq = 0, tScale = 0, cFreq = 0, cScale = 0, raf = 0, active = false;
      const lerp = (a: number, b: number, t: number) => a + (b-a)*t;

      function loop() {
        cFreq  = lerp(cFreq,  tFreq,  0.08);
        cScale = lerp(cScale, tScale, 0.08);
        seed += 0.02;
        turb.setAttribute('baseFrequency', `${cFreq.toFixed(4)} ${(cFreq*0.6).toFixed(4)}`);
        turb.setAttribute('seed', String(Math.floor(seed)));
        dispmap.setAttribute('scale', String(cScale.toFixed(1)));
        if (active || cFreq > 0.001 || cScale > 0.5) raf = requestAnimationFrame(loop);
        else { cancelAnimationFrame(raf); raf = 0; }
      }

      stage.addEventListener('mouseenter', () => { active = true; if (!raf) raf = requestAnimationFrame(loop); });
