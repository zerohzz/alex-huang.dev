    (() => {
      const stage  = document.querySelector('#mosaic .img-stage') as HTMLElement;
      const img    = document.getElementById('mosaic-src') as HTMLImageElement;
      const canvas = document.getElementById('mosaic-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;

      const W = stage.offsetWidth, H = stage.offsetHeight;
      canvas.width = W; canvas.height = H;

      const MAX_BLOCK = 28;
      let blockSize = 1, targetBlock = 1, raf = 0;

      function drawMosaic(size: number) {
        if (size <= 1) {
          ctx.imageSmoothingEnabled = true;
          ctx.drawImage(img, 0, 0, W, H);
          return;
        }
        const tmpW = Math.max(1, Math.floor(W / size));
        const tmpH = Math.max(1, Math.floor(H / size));
        const tmp = document.createElement('canvas');
        tmp.width = tmpW; tmp.height = tmpH;
        const tctx = tmp.getContext('2d')!;
        tctx.imageSmoothingEnabled = false;
        tctx.drawImage(img, 0, 0, tmpW, tmpH);
        ctx.imageSmoothingEnabled = false;
        ctx.drawImage(tmp, 0, 0, W, H);
      }

      function loop() {
        const step = (targetBlock - blockSize) * 0.12;
        blockSize += step;
        if (Math.abs(targetBlock - blockSize) < 0.3) blockSize = targetBlock;
        drawMosaic(Math.round(blockSize));
        if (Math.round(blockSize) !== targetBlock) raf = requestAnimationFrame(loop);
        else { raf = 0; }
      }

      // Initial draw
      function init() { ctx.imageSmoothingEnabled = true; ctx.drawImage(img, 0, 0, W, H); }
      if (img.complete) init(); else img.addEventListener('load', init);

      stage.addEventListener('mouseenter', () => {
        targetBlock = MAX_BLOCK;
        if (!raf) raf = requestAnimationFrame(loop);
      });
      stage.addEventListener('mouseleave', () => {
        targetBlock = 1;
        if (!raf) raf = requestAnimationFrame(loop);
      });
    })();

    // ─── 10: Bubble Metaballs / 融球光晕 ─────────────────────
    (() => {
      const stage  = document.querySelector('#metaballs .img-stage') as HTMLElement;
      const canvas = document.getElementById('meta-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;

      interface Ball { x:number; y:number; vx:number; vy:number; r:number; hue:number; }
      const balls: Ball[] = [];
      let mx = CW/2, my = CH/2, active = false, raf = 0;

      function init() {
        balls.length = 0;
        balls.push({ x:CW/2, y:CH/2, vx:0, vy:0, r:40, hue:280 }); // mouse ball
        const hues = [200, 160, 40, 320, 20];
        for (let i = 0; i < 5; i++) {
          balls.push({
            x: Math.random()*CW, y: Math.random()*CH,
            vx: (Math.random()-0.5)*1.2, vy: (Math.random()-0.5)*1.2,
            r: 22 + Math.random()*22, hue: hues[i],
          });
        }
      }

      function frame() {
        ctx.clearRect(0, 0, CW, CH);

        balls[0].x += (mx - balls[0].x) * 0.12;
        balls[0].y += (my - balls[0].y) * 0.12;

        for (let i = 1; i < balls.length; i++) {
          const b = balls[i];
          b.x += b.vx; b.y += b.vy;
          if (b.x < b.r || b.x > CW-b.r) b.vx *= -1;
          if (b.y < b.r || b.y > CH-b.r) b.vy *= -1;
        }

        // Draw glow blobs
        for (const b of balls) {
          const gr = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r * 2);
          gr.addColorStop(0,   `hsla(${b.hue},100%,70%,0.7)`);
          gr.addColorStop(0.5, `hsla(${b.hue},100%,60%,0.3)`);
          gr.addColorStop(1,   `hsla(${b.hue},100%,55%,0)`);
          ctx.beginPath();
          ctx.arc(b.x, b.y, b.r * 2, 0, Math.PI*2);
          ctx.fillStyle = gr;
          ctx.fill();
        }

        // Bézier bridge between close balls (simulate metaball merge)
        for (let i = 0; i < balls.length; i++) {
          for (let j = i+1; j < balls.length; j++) {
            const a = balls[i], b = balls[j];
            const dx = b.x-a.x, dy = b.y-a.y;
            const dist = Math.sqrt(dx*dx+dy*dy);
            const threshold = a.r + b.r + 30;
            if (dist < threshold) {
              const t2 = 1 - dist/threshold;
              const mx2 = (a.x+b.x)/2, my2 = (a.y+b.y)/2;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.quadraticCurveTo(mx2, my2, b.x, b.y);
              ctx.strokeStyle = `hsla(${(a.hue+b.hue)/2},100%,65%,${t2*0.4})`;
              ctx.lineWidth = (a.r+b.r)*t2*0.35;
              ctx.lineCap = 'round';
              ctx.stroke();
            }
          }
        }

        if (active) raf = requestAnimationFrame(frame);
        else raf = 0;
      }

      init();
      stage.addEventListener('mouseenter', () => {
        active = true;
        if (!raf) raf = requestAnimationFrame(frame);
      });
      stage.addEventListener('mouseleave', () => { active = false; ctx.clearRect(0,0,CW,CH); });
      stage.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        mx = e.clientX - rect.left;
        my = e.clientY - rect.top;
      });
    })();

    // ─── 11: Glow Trail / 发光轨迹 ────────────────────────────
    (() => {
      const stage  = document.querySelector('#glow-trail .img-stage') as HTMLElement;
      const canvas = document.getElementById('trail-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;

      interface Spark { x:number; y:number; vx:number; vy:number; r:number; alpha:number; hue:number; }
      const sparks: Spark[] = [];
      let hue = 0, active = false, raf = 0;

      function frame() {
        // Fade canvas slowly
        ctx.fillStyle = 'rgba(0,0,0,0.12)';
        ctx.fillRect(0, 0, CW, CH);

        for (let i = sparks.length-1; i >= 0; i--) {
          const s = sparks[i];
          s.x += s.vx; s.y += s.vy;
          s.vy += 0.06;
          s.alpha -= 0.022; s.r *= 0.965;
          if (s.alpha <= 0) { sparks.splice(i,1); continue; }
          const gr = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r);
          gr.addColorStop(0,   `hsla(${s.hue},100%,80%,${s.alpha})`);
          gr.addColorStop(0.4, `hsla(${s.hue},100%,60%,${s.alpha*0.5})`);
          gr.addColorStop(1,   'transparent');
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
          ctx.fillStyle = gr; ctx.fill();
        }

        if (sparks.length > 0 || active) raf = requestAnimationFrame(frame);
        else { raf = 0; ctx.clearRect(0,0,CW,CH); }
      }

      stage.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        const cx = e.clientX - rect.left, cy = e.clientY - rect.top;
        hue = (hue + 4) % 360;
        for (let i = 0; i < 6; i++) {
          const a = Math.random()*Math.PI*2, sp = Math.random()*2.2+0.4;
          sparks.push({ x:cx, y:cy, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp-1.2,
