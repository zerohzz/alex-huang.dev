  </div><!-- /.grid -->

  <script>
    // ─── 1: 3D Perspective Tilt / 3D 透视倾斜 ─────────────────
    (() => {
      const stage = document.querySelector('#tilt .img-stage') as HTMLElement;
      const inner = stage.querySelector('.tilt-inner') as HTMLElement;
      const shine = stage.querySelector('.tilt-shine') as HTMLElement;
      let tRx = 0, tRy = 0, cRx = 0, cRy = 0, raf = 0, active = false;

      function loop() {
        cRx += (tRx - cRx) * 0.1;
        cRy += (tRy - cRy) * 0.1;
        inner.style.transform = `rotateX(${cRx}deg) rotateY(${cRy}deg)`;
        const sx = 50 - cRy * 1.5, sy = 50 + cRx * 1.5;
        shine.style.backgroundImage = `radial-gradient(circle at ${sx}% ${sy}%, rgba(255,255,255,0.22), transparent 65%)`;
        if (active || Math.abs(cRx) > 0.05 || Math.abs(cRy) > 0.05) raf = requestAnimationFrame(loop);
        else { cancelAnimationFrame(raf); raf = 0; }
      }

      stage.addEventListener('mouseenter', () => { active = true; if (!raf) raf = requestAnimationFrame(loop); });
      stage.addEventListener('mouseleave', () => { active = false; tRx = 0; tRy = 0; });
      stage.addEventListener('mousemove', (e: MouseEvent) => {
        const r = stage.getBoundingClientRect();
        tRy =  ((e.clientX - r.left) / r.width  - 0.5) * 32;
        tRx = -((e.clientY - r.top)  / r.height - 0.5) * 26;
      });
    })();

    // ─── 2: RGB Glitch / RGB 故障艺术 ─────────────────────────
    (() => {
      const stage = document.querySelector('#glitch .img-stage') as HTMLElement;
      const r = stage.querySelector('.glitch-r') as HTMLElement;
      const g = stage.querySelector('.glitch-g') as HTMLElement;
      const b = stage.querySelector('.glitch-b') as HTMLElement;
      let iv: ReturnType<typeof setInterval> | null = null;

      const rnd = (a: number, z: number) => Math.random() * (z - a) + a;

      function frame() {
        const rx = rnd(-14, 14), gx = rnd(-9, 9), bx = rnd(-11, 11);
        const y1 = rnd(0, 60), y2 = y1 + rnd(8, 30);
        const y3 = rnd(30, 90), y4 = y3 + rnd(5, 25);
        r.style.transform = `translateX(${rx}px)`;
        g.style.transform = `translateX(${gx}px)`;
        b.style.transform = `translateX(${bx}px)`;
        r.style.clipPath = Math.random() > 0.4 ? `polygon(0 ${y1}%, 100% ${y1}%, 100% ${y2}%, 0 ${y2}%)` : 'none';
        g.style.clipPath = Math.random() > 0.5 ? `polygon(0 ${y3}%, 100% ${y3}%, 100% ${y4}%, 0 ${y4}%)` : 'none';
        b.style.clipPath = 'none';
      }

      stage.addEventListener('mouseenter', () => { stage.classList.add('glitching'); iv = setInterval(frame, 60); });
      stage.addEventListener('mouseleave', () => {
        stage.classList.remove('glitching');
        if (iv) clearInterval(iv);
        [r, g, b].forEach(el => { el.style.transform = ''; el.style.clipPath = ''; });
      });
    })();

    // ─── 3: Particle Burst / 粒子爆炸 ─────────────────────────
    (() => {
      const stage = document.querySelector('#particles .img-stage') as HTMLElement;
      const img   = document.getElementById('particle-src') as HTMLImageElement;
      const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
      const ctx   = canvas.getContext('2d')!;

      canvas.width  = stage.offsetWidth;
      canvas.height = stage.offsetHeight;

      interface P { x:number; y:number; vx:number; vy:number; size:number; color:string; alpha:number; decay:number; }
      const ps: P[] = [];
      let raf = 0;

      function sample(cx: number, cy: number) {
        const off = document.createElement('canvas');
        off.width  = img.naturalWidth  || 190;
        off.height = img.naturalHeight || 248;
        const o = off.getContext('2d')!;
        o.drawImage(img, 0, 0);
        const sx = off.width  / stage.offsetWidth;
        const sy = off.height / stage.offsetHeight;
        try {
          const px = o.getImageData(Math.floor(cx*sx), Math.floor(cy*sy), 1, 1).data;
          return `rgb(${px[0]},${px[1]},${px[2]})`;
        } catch { return '#AF8F6F'; }
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (let i = ps.length - 1; i >= 0; i--) {
          const p = ps[i];
          p.x += p.vx; p.y += p.vy; p.vy += 0.13;
          p.alpha -= p.decay; p.size *= 0.97;
          if (p.alpha <= 0) { ps.splice(i, 1); continue; }
          ctx.globalAlpha = p.alpha;
          ctx.fillStyle = p.color;
          ctx.beginPath(); ctx.arc(p.x, p.y, p.size, 0, Math.PI*2); ctx.fill();
        }
        ctx.globalAlpha = 1;
        raf = ps.length > 0 ? requestAnimationFrame(animate) : 0;
      }

      stage.addEventListener('click', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        const cx = e.clientX - rect.left, cy = e.clientY - rect.top;
        const col = sample(cx, cy);
        for (let i = 0; i < 80; i++) {
          const a = Math.random() * Math.PI * 2, sp = Math.random() * 5.5 + 1;
          ps.push({ x:cx, y:cy, vx:Math.cos(a)*sp, vy:Math.sin(a)*sp - Math.random()*2,
