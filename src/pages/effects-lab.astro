    // ─── 14: Spotlight Reveal / 聚光灯 ─────────────────────────
    (() => {
      const stage  = document.querySelector('#spotlight .img-stage') as HTMLElement;
      const canvas = document.getElementById('spot-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;
      let mx = CW/2, my = CH/2, radius = 0, tRadius = 0, raf = 0, active = false;

      function draw() {
        ctx.clearRect(0, 0, CW, CH);
        if (radius < 0.5 && !active) return;
        ctx.fillStyle = 'rgba(0,0,0,0.9)';
