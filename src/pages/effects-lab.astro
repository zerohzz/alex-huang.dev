      stage.addEventListener('mouseenter', () => { active = true; tRadius = 70; if (!raf) raf = requestAnimationFrame(loop); });
      stage.addEventListener('mouseleave', () => { active = false; tRadius = 0; if (!raf) raf = requestAnimationFrame(loop); });
