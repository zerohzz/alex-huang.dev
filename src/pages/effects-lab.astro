    // ─── 15: Glass Shatter — pure CSS, no JS ──────────────────

    // ─── 16: Thermal Vision / 热成像仪 ─────────────────────────
    (() => {
      const img    = document.getElementById('thermal-src') as HTMLImageElement;
      const canvas = document.getElementById('thermal-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;

      function thermalRGB(brightness: number): [number, number, number] {
        const t = brightness / 255;
        if (t < 0.2)  { const s=t/0.2;        return [Math.floor(80*s),  0,                    Math.floor(180+75*s)];  }
        if (t < 0.45) { const s=(t-0.2)/0.25;  return [0,                 Math.floor(200*s),     Math.floor(255-255*s)]; }
        if (t < 0.7)  { const s=(t-0.45)/0.25; return [Math.floor(255*s), 255,                   Math.floor(80-80*s)];   }
        /* else */     { const s=(t-0.7)/0.3;   return [255,               Math.floor(255-255*s), 0];                     }
      }

      function render() {
        const off = document.createElement('canvas');
        off.width = CW; off.height = CH;
        const octx = off.getContext('2d')!;
        octx.drawImage(img, 0, 0, CW, CH);
        const src = octx.getImageData(0, 0, CW, CH).data;
        const out = ctx.createImageData(CW, CH);
        const dst = out.data;
        for (let i = 0; i < src.length; i += 4) {
          const br = src[i]*0.299 + src[i+1]*0.587 + src[i+2]*0.114;
          const [r, g, b] = thermalRGB(br);
          dst[i]=r; dst[i+1]=g; dst[i+2]=b; dst[i+3]=255;
        }
        ctx.putImageData(out, 0, 0);
      }

      if (img.complete && img.naturalWidth > 0) render();
      else img.addEventListener('load', render, { once: true });
    })();

    // ─── 17: Water Wave / 水波扭曲 ─────────────────────────────
    (() => {
      const stage  = document.querySelector('#wave .img-stage') as HTMLElement;
      const img    = document.getElementById('wave-src') as HTMLImageElement;
      const canvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;

      let off: HTMLCanvasElement | null = null;
      let t = 0, amp = 0, tAmp = 0, raf = 0;

      function ensureOff() {
        if (off) return;
        off = document.createElement('canvas');
        off.width = CW; off.height = CH;
        off.getContext('2d')!.drawImage(img, 0, 0, CW, CH);
      }

      function draw() {
        if (!off) return;
        ctx.clearRect(0, 0, CW, CH);
        for (let y = 0; y < CH; y++) {
          const offset = Math.sin(y * 0.09 + t) * amp;
          ctx.drawImage(off, 0, y, CW, 1, offset, y, CW, 1);
        }
      }

      function loop() {
        t += 0.045;
        amp += (tAmp - amp) * 0.06;
        draw();
        raf = requestAnimationFrame(loop);
      }

      function init() { ensureOff(); draw(); if (!raf) raf = requestAnimationFrame(loop); }
      if (img.complete && img.naturalWidth > 0) init();
      else img.addEventListener('load', init, { once: true });

      stage.addEventListener('mouseenter', () => { tAmp = 12; });
      stage.addEventListener('mouseleave', () => { tAmp = 0; });
      stage.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        const dx = (e.clientX - rect.left - CW/2) / (CW/2);
        const dy = (e.clientY - rect.top  - CH/2) / (CH/2);
        tAmp = Math.sqrt(dx*dx+dy*dy) * 14;
      });
    })();

    // ─── 18: Aurora Diffusion / 极光弥散 ──────────────────────
    (() => {
      const stage  = document.querySelector('#aurora .img-stage') as HTMLElement;
      const canvas = document.getElementById('aurora-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;
      const CW = 190, CH = 248;
      canvas.width = CW; canvas.height = CH;

      interface ACol { x: number; w: number; hue: number; spd: number; phase: number; alpha: number; }
      let cols: ACol[] = [];
      let t = 0, active = false, raf = 0;

      function spawnAt(atX: number) {
        cols = [];
        for (let i = 0; i < 7; i++) {
          cols.push({
            x: atX + (Math.random()-0.5) * 90,
            w: 12 + Math.random()*22,
            hue: 140 + Math.random()*200,
            spd: 0.4 + Math.random()*0.7,
            phase: Math.random()*Math.PI*2,
            alpha: 0.35 + Math.random()*0.35,
          });
        }
      }

      function frame() {
        ctx.clearRect(0, 0, CW, CH);
        t += 0.018;
        for (const c of cols) {
          const cx = c.x + Math.sin(t*c.spd + c.phase) * 14;
          const hue2 = (c.hue + t*12) % 360;
          const grad = ctx.createLinearGradient(0, 0, 0, CH);
          grad.addColorStop(0,    `hsla(${hue2},100%,72%,0)`);
          grad.addColorStop(0.08, `hsla(${hue2},100%,72%,${c.alpha})`);
          grad.addColorStop(0.5,  `hsla(${(hue2+40)%360},100%,65%,${c.alpha*0.65})`);
          grad.addColorStop(0.88, `hsla(${(hue2+80)%360},100%,58%,${c.alpha*0.25})`);
          grad.addColorStop(1,    `hsla(${(hue2+100)%360},100%,55%,0)`);
          ctx.save();
          ctx.globalAlpha = 1;
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.ellipse(cx, CH/2, c.w/2, CH*0.52, 0, 0, Math.PI*2);
          ctx.fill();
          ctx.restore();
        }
        if (active) raf = requestAnimationFrame(frame);
        else { ctx.clearRect(0,0,CW,CH); raf = 0; }
      }

      stage.addEventListener('mouseenter', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        active = true;
        spawnAt(e.clientX - rect.left);
        if (!raf) raf = requestAnimationFrame(frame);
      });
      stage.addEventListener('mouseleave', () => { active = false; });
      stage.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = stage.getBoundingClientRect();
        spawnAt(e.clientX - rect.left);
      });
    })();
  </script>

</body>
</html>
