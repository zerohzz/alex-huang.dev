---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Font Lab — alex-huang.dev"
  description="Font preview playground — hidden utility page."
  noindex={true}
>
  <main id="main-content" class="w-full max-w-5xl mx-auto px-4 pt-12 pb-24">
    <header class="mb-10">
      <h1 class="text-3xl font-bold mb-1">Font Lab</h1>
      <p class="text-sm text-text-muted">Click a card to select the font. Preview text is editable.</p>
    </header>

    <div
      contenteditable="true"
      id="preview-text"
      class="w-full text-4xl font-semibold leading-tight mb-10 outline-none border-b border-border pb-4 focus:border-accent transition-colors"
      style="font-family: var(--font-outfit, 'Outfit', sans-serif);"
      suppressContentEditableWarning={true}
    >
      The quick brown fox jumps over the lazy dog.
    </div>

    <div id="font-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-24">
    </div>
  </main>

  <!-- Fixed bottom bar -->
  <div
    id="font-bar"
    class="fixed bottom-0 left-0 right-0 border-t border-border bg-background/90 backdrop-blur-sm px-6 py-3 flex items-center justify-between text-sm z-50"
  >
    <span class="font-semibold text-foreground" id="bar-name">Outfit (current)</span>
    <span class="font-mono text-text-muted text-xs" id="bar-family">'Outfit', sans-serif</span>
    <button
      id="copy-btn"
      class="text-xs px-3 py-1 rounded-full border border-border hover:border-accent hover:text-accent transition-colors"
    >
      Copy CSS
    </button>
  </div>
</Layout>

<style is:global>
  .font-card {
    cursor: pointer;
    border: 1px solid var(--border);
    background: var(--card);
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 150ms, box-shadow 150ms, transform 150ms;
  }
  .font-card:hover {
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 10%, transparent);
    transform: translateY(-2px);
  }
  .font-card.selected {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .font-card .sample {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    color: var(--foreground);
  }
  .font-card .meta {
    font-size: 0.69rem;
    color: var(--text-muted);
    line-height: 1.5;
    font-family: inherit;
  }
  .font-card .tag {
    display: inline-block;
    font-size: 0.6rem;
    font-family: 'Courier New', monospace;
    color: color-mix(in srgb, var(--text-muted) 70%, transparent);
    margin-top: 0.35rem;
  }
  .font-card .label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: 0.25rem;
  }
  .font-card .current-badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 20%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    margin-left: 6px;
    vertical-align: middle;
  }
  .font-group-header {
    grid-column: 1 / -1;
    padding: 0.5rem 0 0.25rem;
    border-top: 1px solid var(--border);
    margin-top: 0.5rem;
  }
  .font-group-header:first-child {
    border-top: none;
    margin-top: 0;
  }
  .font-group-header h2 {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: 'Courier New', monospace;
  }
  .font-group-header p {
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }
</style>

<script is:inline>
  const FONTS = [
    // ── Sans-serif ──────────────────────────────────────────────
    { _group: "sans" },
    {
      name: "Outfit",
      family: "'Outfit', sans-serif",
      url: null,
      current: true,
      sample: "Aa Bb Cc",
      note: "几何无衬线，字形开放，阅读舒适。当前使用字体。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "DM Sans",
      family: "'DM Sans', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "几何骨架但笔触偏人文，x 字高适中，有温度感。最接近 Styrene 的免费替代。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Nunito Sans",
      family: "'Nunito Sans', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "圆润末端，比 Inter 更有个性，与「亲和而专业」的气质高度吻合。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Plus Jakarta Sans",
      family: "'Plus Jakarta Sans', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "现代感强，字形清晰，字重丰富，标题和正文均可胜任。近 Styrene B 气质。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Figtree",
      family: "'Figtree', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "近年新秀，笔画简洁、比例均衡，轻量级使用感极好，适合界面文字。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Inter",
      family: "'Inter', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Claude UI / Figma default",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Manrope",
      family: "'Manrope', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Geometric, readable",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Geist",
      family: "'Geist', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Geist:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Vercel's typeface",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Space Grotesk",
      family: "'Space Grotesk', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Developer aesthetic",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Albert Sans",
      family: "'Albert Sans', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Minimal geometric",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Lexend",
      family: "'Lexend', sans-serif",
      url: "https://fonts.googleapis.com/css2?family=Lexend:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Readability-first",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Satoshi",
      family: "'Satoshi', sans-serif",
      url: "https://api.fontshare.com/v2/css?f[]=satoshi@400,600,700&display=swap",
      sample: "Aa Bb Cc",
      note: "Polished modern",
      tag: "Fontshare · OFL",
    },
    // ── Serif ────────────────────────────────────────────────────
    { _group: "serif" },
    {
      name: "Crimson Pro",
      family: "'Crimson Pro', serif",
      url: "https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "过渡型衬线，历史感与现代感平衡极好，正文可读性极强，气质沉稳。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Libre Baskerville",
      family: "'Libre Baskerville', serif",
      url: "https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap",
      sample: "Aa Bb Cc",
      note: "经典 Baskerville 的开源复刻，对标「书卷感大标题」场景。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Source Serif 4",
      family: "'Source Serif 4', serif",
      url: "https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Adobe 出品的开源衬线，过渡型结构，屏幕可读性一流，字重完整。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Newsreader",
      family: "'Newsreader', serif",
      url: "https://fonts.googleapis.com/css2?family=Newsreader:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "专为长文阅读优化的过渡型衬线，气质与 Tiempo Text 最接近。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Lora",
      family: "'Lora', serif",
      url: "https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "笔触带有书法感的现代衬线，正文排版优雅，与温暖克制的整体风格契合。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Playfair Display",
      family: "'Playfair Display', serif",
      url: "https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "高对比度过渡型衬线，标题场景首选，气质优雅强劲。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Merriweather",
      family: "'Merriweather', serif",
      url: "https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&display=swap",
      sample: "Aa Bb Cc",
      note: "专为屏幕阅读设计的衬线主力，字形宽松，长文舒适度极高。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "EB Garamond",
      family: "'EB Garamond', serif",
      url: "https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Garamond 经典复刻，旧式人文衬线，书卷气浓郁，历史底蕴深厚。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Cormorant Garamond",
      family: "'Cormorant Garamond', serif",
      url: "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "笔画极细，对比强烈，气质奢侈精致，适合大号标题展示。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "PT Serif",
      family: "'PT Serif', serif",
      url: "https://fonts.googleapis.com/css2?family=PT+Serif:wght@400;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Paratype 出品，为屏幕优化的过渡型衬线，多语言支持优秀。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Spectral",
      family: "'Spectral', serif",
      url: "https://fonts.googleapis.com/css2?family=Spectral:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "Google Fonts 原创，专为数字长文优化，精细度与 Source Serif 4 并驾齐驱。",
      tag: "Google Fonts · OFL",
    },
    {
      name: "Bitter",
      family: "'Bitter', serif",
      url: "https://fonts.googleapis.com/css2?family=Bitter:wght@400;600;700&display=swap",
      sample: "Aa Bb Cc",
      note: "专为屏幕正文设计，x 字高大，衬线粗壮，低分辨率下依然清晰易读。",
      tag: "Google Fonts · OFL",
    },
  ];

  const GROUP_META = {
    sans: { label: "无衬线类", sub: "Sans-serif — 对标 Styrene / Söhne" },
    serif: { label: "衬线类", sub: "Serif — 对标 Galaxie Copernicus / Tiempo Text" },
  };

  // Flat list of actual font entries (no group markers)
  const FONT_ENTRIES = FONTS.filter(f => !f._group);
  let selectedIndex = 0;

  function loadFont(font) {
    if (!font.url) return;
    if (document.querySelector(`link[data-font="${font.name}"]`)) return;
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = font.url;
    link.setAttribute("data-font", font.name);
    document.head.appendChild(link);
  }

  function applyFont(index) {
    selectedIndex = index;
    const font = FONT_ENTRIES[index];
    loadFont(font);

    const preview = document.getElementById("preview-text");
    if (preview) preview.style.fontFamily = font.family;

    const barName = document.getElementById("bar-name");
    const barFamily = document.getElementById("bar-family");
    if (barName) barName.textContent = font.name + (font.current ? " (current)" : "");
    if (barFamily) barFamily.textContent = font.family;

    document.querySelectorAll(".font-card").forEach((card, i) => {
      card.classList.toggle("selected", i === index);
    });
  }

  function buildGrid() {
    const grid = document.getElementById("font-grid");
    if (!grid) return;
    grid.innerHTML = "";

    let fontIndex = 0;
    let isFirst = true;

    FONTS.forEach(item => {
      if (item._group) {
        const meta = GROUP_META[item._group];
        const header = document.createElement("div");
        header.className = "font-group-header" + (isFirst ? " first-child" : "");
        if (isFirst) header.style.borderTop = "none";
        header.innerHTML = `
          <h2>${meta.label}</h2>
          <p>${meta.sub}</p>
        `;
        grid.appendChild(header);
        isFirst = false;
        return;
      }

      const i = fontIndex++;
      const card = document.createElement("div");
      card.className = "font-card" + (i === 0 ? " selected" : "");
      card.innerHTML = `
        <div class="label">
          ${item.name}
          ${item.current ? '<span class="current-badge">current</span>' : ""}
        </div>
        <div class="sample" style="font-family: ${item.family};">${item.sample}</div>
        <div class="meta">${item.note}</div>
        ${item.tag ? `<div class="tag">${item.tag}</div>` : ""}
      `;
      card.addEventListener("click", () => {
        applyFont(i);
        loadFont(item);
      });
      card.addEventListener("mouseenter", () => loadFont(item));
      grid.appendChild(card);
    });
  }

  function setupCopyBtn() {
    const btn = document.getElementById("copy-btn");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const font = FONT_ENTRIES[selectedIndex];
      const css = `font-family: ${font.family};`;
      navigator.clipboard.writeText(css).then(() => {
        btn.textContent = "Copied!";
        setTimeout(() => (btn.textContent = "Copy CSS"), 1500);
      });
    });
  }

  function init() {
    buildGrid();
    setupCopyBtn();
  }

  // Immediate call (direct navigation / script runs after DOM is ready)
  if (document.getElementById("font-grid")) {
    init();
  }
  // Also listen for client-side navigation
  document.addEventListener("astro:page-load", init);
</script>
