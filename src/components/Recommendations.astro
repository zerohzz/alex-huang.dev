---
// ─── Recommendations ──────────────────────────────────────────────────────────
// Data source: src/data/recommendations.md
// Edit the YAML frontmatter in that file to update people, quotes, and evidence paths.

const recFile = await import('../data/recommendations.md');
const recommendations = (recFile as any).frontmatter.recommendations as Array<{
  name: string;
  title: string;
  company: string;
  relationship: string;
  linkedinUrl: string;
  highlights: string[];
  excerpt: string;
  fullReview: string;
  evidencePath: string;
}>;

// Morandi-style avatar palette — one colour per person, low saturation, calm
const AVATAR_PALETTE = [
  { bg: '#D4C5B0', text: '#6B5A47' }, // muted beige      — Abhishek
  { bg: '#C4A8A8', text: '#7A4F4F' }, // dusty rose       — Anirudh
  { bg: '#A8BAA8', text: '#4A6B4A' }, // sage green       — Sabine
  { bg: '#A0AFBE', text: '#3A5570' }, // desaturated blue — Toran
  { bg: '#C4AA8C', text: '#7A5A3A' }, // soft terracotta  — Sushant
  { bg: '#B5AFA8', text: '#5A5550' }, // warm grey        — Heya
];

// Wrap highlight phrases with a span for accent styling.
// Sort by length descending so longer phrases match before their substrings.
function highlightExcerpt(text: string, phrases: string[] = []): string {
  const sorted = [...phrases].sort((a, b) => b.length - a.length);
  let result = text;
  for (const phrase of sorted) {
    const escaped = phrase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    result = result.replace(
      new RegExp(`(${escaped})`, 'gi'),
      '<span class="rec-hl">$1</span>'
    );
  }
  return result;
}
---

<section id="recommendations" class="w-full border-t border-border mt-16 pt-16 pb-8" data-fade-up>

  <!-- Section header -->
  <div class="text-center mb-12">
    <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">Recommendations</p>
    <h2 class="text-3xl md:text-4xl font-bold mb-4">What colleagues say</h2>
  </div>

  <!-- Cards grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
    {recommendations.map((rec, i) => {
      const palette = AVATAR_PALETTE[i % AVATAR_PALETTE.length];
      const initials = rec.name.split(' ').map((n: string) => n[0]).join('');
      const highlightedExcerpt = highlightExcerpt(rec.excerpt, rec.highlights);
      return (
        <div class="group flex flex-col bg-card border border-border rounded-2xl p-6 shadow-sm hover:bg-accent hover:border-accent hover:shadow-lg transition-all duration-300 cursor-default">

          <!-- Quotation mark (centered) -->
          <div class="text-center mb-3 select-none">
            <span class="text-accent group-hover:text-white/80 transition-colors text-4xl leading-none" style="font-family: Georgia, 'Times New Roman', serif;">"</span>
          </div>

          <!-- Quote block -->
          <div class="flex-1 mb-6">
            <!-- Quote text — excerpt (with highlights) by default; full review on hover -->
            <p class="text-sm text-foreground/90 group-hover:text-white/90 italic leading-relaxed min-h-[4.5rem] transition-colors">
              <span class="group-hover:hidden" set:html={highlightedExcerpt} />
              <span class="hidden group-hover:inline">{rec.fullReview}</span>
            </p>
          </div>

          <!-- Person info -->
          <div class="flex items-center gap-3 mb-3">
            <!-- Morandi avatar -->
            <div
              class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm select-none"
              style={`background-color: ${palette.bg}; color: ${palette.text};`}
            >
              {initials}
            </div>
            <div class="min-w-0">
              <!-- Name + LinkedIn icon -->
              <div class="flex items-center gap-1.5">
                <p class="text-sm font-semibold truncate group-hover:text-white transition-colors">{rec.name}</p>
                <a
                  href={rec.linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="shrink-0 text-[#0A66C2] group-hover:text-white/80 hover:opacity-75 transition-all"
                  aria-label={`${rec.name} on LinkedIn`}
                  title={`${rec.name} on LinkedIn`}
                >
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              </div>
              <p class="text-xs text-text-muted group-hover:text-white/70 truncate transition-colors">{rec.title} · {rec.company}</p>
            </div>
          </div>

          <!-- Relationship -->
          <p class="text-xs text-text-muted group-hover:text-white/60 mb-5 italic transition-colors">{rec.relationship}</p>

          <!-- CTA -->
          <a
            href={rec.evidencePath}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-medium text-accent group-hover:text-white hover:opacity-75 transition-all mt-auto group/link"
            aria-label={`View recognition from ${rec.name}`}
          >
            View More
            <svg class="w-3 h-3 shrink-0 transition-transform group-hover/link:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>

        </div>
      );
    })}
  </div>
</section>

<style>
  /* Highlighted keyword inside excerpt — accent colour + shimmer underline */
  :global(.rec-hl) {
    color: var(--color-accent);
    font-weight: 600;
    font-style: normal;
    position: relative;
    display: inline;
  }

  :global(.rec-hl)::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: var(--color-accent);
    opacity: 0.30;
    border-radius: 1px;
    transform: scaleX(0.65);
    transform-origin: left center;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  /* Underline shimmer expands on card hover */
  :global(.group:hover .rec-hl)::after {
    transform: scaleX(1);
    opacity: 0.60;
  }
</style>
