---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-0.5 rounded-full border border-border px-3 py-1",
      "text-text-muted transition-all duration-200",
      "hover:border-accent hover:bg-accent hover:text-white",
      "focus-visible:border-none focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent",
      { "text-xs": size === "sm" },
      { "text-sm": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-70",
        { "size-3": size === "sm" },
        { "size-4": size === "lg" },
      ]}
    />
    {tagName}
  </a>
</li>
